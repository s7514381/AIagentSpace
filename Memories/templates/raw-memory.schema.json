{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI Agent Space Raw Memory",
  "type": "object",
  "required": [
    "id",
    "type",
    "status",
    "createdAt",
    "updatedAt",
    "project",
    "summary",
    "importance",
    "messages"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "superseded",
        "unverified",
        "archived",
        "purge_candidate"
      ]
    },
    "createdAt": {
      "type": "string"
    },
    "updatedAt": {
      "type": "string"
    },
    "project": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "importance": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "filesMentioned": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "messages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "role",
          "content"
        ],
        "properties": {
          "role": {
            "type": "string"
          },
          "content": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "decisions": {
      "type": "array"
    },
    "todos": {
      "type": "array"
    },
    "warnings": {
      "type": "array"
    }
  },
  "additionalProperties": true
}
